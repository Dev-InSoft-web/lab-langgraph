              "mode": "raw",
              "raw": "{\n  \"project\": \"patyia\",\n  \"catalogId\": \"GET-conversacion\",\n  \"allowMutations\": false\n}"
            },
            "url": "{{baseUrl}}/agent/execute"
          }
        }
      ]
    },
    {
