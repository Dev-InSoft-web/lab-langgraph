k8/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "44", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/yVK0_IQJzk8/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "45", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/yVK0_IQJzk8/maxresdefault.webp", "description": "Módulo de nómina de ContaPyme® y AgroWin® - Tema: Ajuste a cero y cruce de provisiones de nómina (cruce de referencias)\n\nDescripción:\nAprenda cómo ajustar las diferencias entre las prestaciones sociales provisionadas y los pagos efectuados, paso fundamental para garantizar que la contabilidad y los informes financieros estén debidamente cuadrados. Luego, comprenda cómo realizar un proceso de cruce de referencias de nómina con las cuentas por pagar para garantizar una conciliación precisa de las provisiones y sus referencias, lo que ayudará a minimizar errores y a garantizar que los informes de cartera estén correctos y la contabilidad sean precisos.\n\nExperta: Viviana Restrepo\nEspecialista en producto de InSoft®\n\nSíganos en nuestras redes sociales:\nFacebook /SoftwareContableContaPyme \nInstagram /contapyme \n\nConozca más en www.contapyme.com y www.agrowin.com", "channel_id": "UCPeasMTjLab3kMBdRvG7vAg", "channel_url": "https://www.youtube.com/channel/UCPeasMTjLab3kMBdRvG7vAg", "duration": 1352, "view_count": 246, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=yVK0_IQJzk8", "categories": ["Education"], "tags": ["Software Contable", "ContaPyme", "Sistema de Facturación", "Contabilidad", "Programa Contable", "NIIF"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {"es-orig": [{"ext": "json3", "url": "https://www.youtube.com/api/timedtext?v=yVK0_IQJzk8&ei=kBkjaoykCdGuy_sPjvie2AY&caps=asr&opi=112496729&xoaf=5&xowf=1&hl=en&i