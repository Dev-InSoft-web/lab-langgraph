pg", "height": 1080, "width": 1920, "preference": -1, "id": "44", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/X6M3Fpp4BEk/maxresdefault.webp", "preference": 0, "id": "45"}], "thumbnail": "https://i.ytimg.com/vi/X6M3Fpp4BEk/maxresdefault.jpg", "description": "Módulo de costos de ContaPyme® y AgroWin® - Tema: Cultivos transitorios\n\nDescripción:\nComprenda los diferentes eventos que suceden durante el ciclo productivo de un cultivo transitorio y que deben registrarse en el sistema para una correcta obtención de informes contables y de costos de producción. Se trata temas como la recapitulación de conceptos como: manejo de las cuentas de producto en proceso, cuentas de producción, cierres de mes (distribuciones de costos indirectos y auto activación), el proceso contable de los costos y los criterios de codificación para los cultivos. Conozca los pasos para realizar desde el sistema AgroWin la creación de un cultivo transitorio, imputación de costos, tratamiento de la producción, informes de producción y ventas, finalización y erradicación de un cultivo transitorio.\n\nExperta: Ing. Diana María Menjura\nEspecialista en producto de InSoft®\n\nSíganos en nuestras redes sociales:\nFacebook /SoftwareContableContaPyme \nInstagram /contapyme \n\nConozca más en www.contapyme.com y www.agrowin.com", "channel_id": "UCPeasMTjLab3kMBdRvG7vAg", "channel_url": "https://www.youtube.com/channel/UCPeasMTjLab3kMBdRvG7vAg", "duration": 1487, "view_count": 36, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=X6M3Fpp4BEk", "categories": ["Education"], "tags": ["Software Contable", "ContaPyme", "Sistema de Facturación", "Contabilidad", "Programa Contable", "NIIF"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {"es-orig": [{"ext": "json3", "url": "https://www.youtube.com/api/timedtext